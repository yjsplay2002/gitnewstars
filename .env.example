# ---- Auth.js (Google login) ----
# Generate a secret:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=

# Google OAuth client (https://console.cloud.google.com → APIs & Services → Credentials)
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://<your-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Only this Google account can edit Korean descriptions.
ADMIN_EMAIL=yjs@lnrgame.com

# ---- Data repo (history archive + admin edits) ----
# The GitHub repo that stores data/overrides.json and data/weeks/*.json.
# Usually the same repo you deploy from.
GH_DATA_REPO=your-github-username/GitNewStars

# Fine-grained Personal Access Token with "Contents: Read and write" on GH_DATA_REPO.
# Required ONLY for the in-app admin editor (writing overrides).
GH_TOKEN=

# ---- Visitor counter (Upstash Redis, free tier) ----
# Create a database at https://console.upstash.com → REST API section.
# Without these, the counter silently shows 0 / 0 / 0.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
