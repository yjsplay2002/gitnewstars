# ---- Auth.js (Google login) ----
# Generate a secret:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=

# Google OAuth client (https://console.cloud.google.com → APIs & Services → Credentials)
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://<your-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Only this Google account can edit Korean descriptions.
ADMIN_EMAIL=yjs@lnrgame.com

# ---- Data repo (history archive + admin edits) ----
# The GitHub repo that stores data/overrides.json and data/weeks/*.json.
# Usually the same repo you deploy from.
GH_DATA_REPO=your-github-username/GitNewStars

# Fine-grained Personal Access Token with "Contents: Read and write" on GH_DATA_REPO.
# Required ONLY for the in-app admin editor (writing overrides).
GH_TOKEN=

# ---- Visitor counter (Upstash Redis, free tier) ----
# Create a database at https://console.upstash.com → REST API section.
# Without these, the counter silently shows 0 / 0 / 0.
# Also used as newsletter:subscribers fallback when NEWSLETTER_* is unset.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Newsletter (optional scaffold) ----
# When both are set, POST /api/subscribe forwards via a guarded provider hook
# (TODO: wire body/headers to your chosen service — no vendor hardcoded).
# Without them: Redis set newsletter:subscribers if Upstash is set, else
# graceful 200 "준비 중". Site never breaks when unset.
NEWSLETTER_API_URL=
NEWSLETTER_API_KEY=

# ---- Daily morning digest (/api/newsletter/send) ----
# Resend API key (https://resend.com → API Keys). Free tier: 100 emails/day.
RESEND_API_KEY=
# Sender. Default "GitNewStars <onboarding@resend.dev>" works only for testing;
# verify a domain in Resend and use e.g. "GitNewStars <daily@yourdomain.com>".
NEWSLETTER_FROM=
# Shared secret for the send endpoint AND unsubscribe-link HMAC.
# Set the same value as a GitHub Actions secret NEWSLETTER_CRON_SECRET
# (used by .github/workflows/newsletter.yml). Generate: openssl rand -hex 24
NEWSLETTER_CRON_SECRET=
